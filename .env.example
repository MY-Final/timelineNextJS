# ═══════════════════════════════════════════════════════════════════
#  Timeline 环境变量配置
#  复制本文件为 .env.local 并填写对应值
#    cp .env.example .env.local
# ═══════════════════════════════════════════════════════════════════


# ── 数据库 ────────────────────────────────────────────────────────
# DB_TYPE: "self-hosted"（自建 PostgreSQL）或 "supabase"（云数据库）
DB_TYPE=self-hosted

# 【自建 PostgreSQL】DB_TYPE=self-hosted 时必填
# Docker Compose 部署时，DB_HOST 填写 docker-compose 中的服务名 "postgres"
DB_HOST=postgres
DB_PORT=5432
DB_USER=timeline
DB_PASSWORD=timeline_pass
DB_NAME=timeline

# 【Supabase】DB_TYPE=supabase 时必填
# SUPABASE_DB_URL=postgresql://postgres:xxx@xxx.supabase.co:5432/postgres


# ── Redis ─────────────────────────────────────────────────────────
# REDIS_TYPE: "self-hosted"（自建 Redis）或 "upstash"（云 Redis）
REDIS_TYPE=self-hosted

# 【自建 Redis】REDIS_TYPE=self-hosted 时必填
# Docker Compose 部署时，密码需与 docker-compose.yml 中 REDIS_PASSWORD 一致
REDIS_URL=redis://:redis_pass@redis:6379

# 【Upstash】REDIS_TYPE=upstash 时必填
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=AXxx...


# ── JWT 认证 ──────────────────────────────────────────────────────
# 用于签发和验证登录 Token，务必修改为随机强密码
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=请替换为你的随机密钥至少32字符
# Token 过期时间，默认 7d（7 天）
JWT_EXPIRES_IN=7d


# ── Cloudflare R2 对象存储（可选）─────────────────────────────────
# 用于图片上传功能。不配置时图片上传功能不可用
# R2_ACCOUNT_ID=你的Cloudflare账户ID
# R2_ACCESS_KEY_ID=xxx
# R2_SECRET_ACCESS_KEY=xxx
# R2_BUCKET_NAME=timeline-images
# R2_PUBLIC_URL=https://images.yourdomain.com


# ── Supabase 客户端（可选）────────────────────────────────────────
# 仅在使用 Supabase 存储/认证等功能时需要
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJxxx...
